<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- MCP Prompt List View -->
    <record id="view_mcp_prompt_list" model="ir.ui.view">
        <field name="name">mcp.prompt.list</field>
        <field name="model">mcp.prompt</field>
        <field name="arch" type="xml">
            <tree string="MCP Prompts" default_order="sequence, name">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="title"/>
                <field name="owner_id" widget="many2one_avatar_user"/>
                <field name="share_with_all_users"/>
                <field name="description" optional="hide"/>
                <field name="expose_to_mcp_client"/>
                <field name="active" column_invisible="True"/>
            </tree>
        </field>
    </record>

    <!-- MCP Prompt Form View -->
    <record id="view_mcp_prompt_form" model="ir.ui.view">
        <field name="name">mcp.prompt.form</field>
        <field name="model">mcp.prompt</field>
        <field name="arch" type="xml">
            <form string="MCP Prompt">
                <sheet>
                    <!-- Info Banner -->
                    <div class="alert alert-info mb-4" role="status">
                        <h5 class="fw-bold">
                            <i class="fa fa-info-circle me-2" title="Info"/>About MCP Prompts
                        </h5>
                        <p class="mb-2">
                            MCP Prompts are reusable templates that appear in MCP clients (like Claude).
                            When users select a prompt, they provide argument values and receive pre-configured instructions.
                        </p>
                        <hr/>
                        <p class="mb-2"><strong>How it works:</strong></p>
                        <ol class="mb-2">
                            <li>Create a prompt with a unique name (lowercase, underscores allowed)</li>
                            <li>Define arguments that users will provide</li>
                            <li>Write a template using <code>{{argument_name}}</code> placeholders</li>
                            <li>Enable "Expose to MCP Client" to make it available via <code>prompts/list</code></li>
                        </ol>
                        <p class="mb-0">
                            <i class="fa fa-bell me-1" title="Note"/>
                            <em> To see the updated list of prompt templates after new ones are exposed, users will need to disconnect/reconnect to the mcp (or trigger reload of MCP configuration) within the mcp client.</em>
                        </p>
                    </div>

                    <!-- Active Toggle -->
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>

                    <!-- Title Area -->
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g., find_customer"/>
                        </h1>
                        <label for="title"/>
                        <h2>
                            <field name="title" placeholder="e.g., Find Customer"/>
                        </h2>
                        <label for="description"/>
                        <field name="description"
                                   placeholder="Describe what this prompt does..."/>
                    </div>

                    <!-- Main Fields -->
                    <group>
                        <group string="Prompt Settings">
                            <field name="expose_to_mcp_client" widget="boolean_toggle"/>
                            <field name="active" invisible="1"/>
                            <field name="sequence" groups="base.group_no_one"/>
                        </group>
                        <group string="Ownership">
                            <field name="owner_id" widget="many2one_avatar_user"/>
                            <field name="share_with_all_users" widget="boolean_toggle"/>
                            <field name="shared_user_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"
                                   invisible="share_with_all_users"/>
                        </group>
                    </group>

                    <!-- Template Section -->
                    <group string="Prompt Template">
                        <field name="template" nolabel="1" colspan="2"
                               placeholder="Enter your prompt template here. Use {{argument_name}} for placeholders.&#10;&#10;Example:&#10;Search for a customer matching &quot;{{query}}&quot; using search_read on res.partner..."
                               widget="text"/>
                    </group>

                    <!-- Arguments Section -->
                    <group string="Arguments">
                        <field name="argument_ids" nolabel="1" colspan="2">
                            <tree editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="name" placeholder="argument_name"/>
                                <field name="description" placeholder="Description of this argument"/>
                                <field name="required"/>
                            </tree>
                        </field>
                    </group>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- MCP Prompt Search View -->
    <record id="view_mcp_prompt_search" model="ir.ui.view">
        <field name="name">mcp.prompt.search</field>
        <field name="model">mcp.prompt</field>
        <field name="arch" type="xml">
            <search string="Search Prompts">
                <field name="name"/>
                <field name="title"/>
                <field name="description"/>
                <field name="owner_id"/>
                <separator/>
                <filter name="my_prompts" string="My Prompts"
                        domain="[('owner_id', '=', uid)]"/>
                <filter name="shared_with_all" string="Shared with All Users"
                        domain="[('share_with_all_users', '=', True)]"/>
                <filter name="shared_with_me_explicit" string="Shared with Me"
                        domain="[('shared_user_ids', 'in', uid)]"/>
                <filter name="exposed" string="Exposed to MCP"
                        domain="[('expose_to_mcp_client', '=', True)]"/>

                <separator/>
                <filter name="archived" string="Archived"
                        domain="[('active', '=', False)]"/>
                <group>
                    <filter name="group_owner" string="Owner" context="{'group_by': 'owner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- MCP Prompt Action -->
    <record id="action_mcp_prompt" model="ir.actions.act_window">
        <field name="name">Prompts</field>
        <field name="res_model">mcp.prompt</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_mcp_prompt_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first MCP Prompt
            </p>
            <p>
                MCP Prompts are reusable templates that appear
                in AI clients like Claude.
            </p>
        </field>
    </record>
</odoo>
