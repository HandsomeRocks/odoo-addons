<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- MCP Module File List View -->
    <record id="view_mcp_module_file_list" model="ir.ui.view">
        <field name="name">mcp.module.file.list</field>
        <field name="model">mcp.module.file</field>
        <field name="arch" type="xml">
            <tree string="Module Files">
                <field name="sequence" widget="handle"/>
                <field name="file_path"/>
                <field name="file_ext" column_invisible="1"/>
                <field name="module_id" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- MCP Module File Form View -->
    <record id="view_mcp_module_file_form" model="ir.ui.view">
        <field name="name">mcp.module.file.form</field>
        <field name="model">mcp.module.file</field>
        <field name="arch" type="xml">
            <form string="Module File">
                <sheet>
                    <group>
                        <group>
                            <field name="file_path"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="module_id" readonly="1"/>
                            <field name="file_ext" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content" name="content" invisible="binary_content">
                            <field name="content" widget="code" options="{'mode': 'python'}"
                                   invisible="file_ext != '.py'" nolabel="1"/>
                            <field name="content" widget="code" options="{'mode': 'xml'}"
                                   invisible="file_ext != '.xml'" nolabel="1"/>
                            <field name="content" widget="code" options="{'mode': 'js'}"
                                   invisible="file_ext not in ('.js', '.json')" nolabel="1"/>
                            <field name="content" widget="code" options="{'mode': 'scss'}"
                                   invisible="file_ext not in ('.scss', '.css')" nolabel="1"/>
                            <field name="content" widget="code" options="{'mode': 'js'}"
                                   invisible="file_ext in ('.py', '.xml', '.js', '.json', '.scss', '.css')" nolabel="1"/>
                        </page>
                        <page string="Binary" name="binary" invisible="not binary_content">
                            <group>
                                <field name="binary_content" widget="binary"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- MCP Module File Action (opened from smart button) -->
    <record id="action_mcp_module_files" model="ir.actions.act_window">
        <field name="name">Files</field>
        <field name="res_model">mcp.module.file</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_mcp_module_file_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_mcp_module_file_form')})]"/>
        <field name="domain">[('module_id', '=', active_id)]</field>
        <field name="context">{'default_module_id': active_id}</field>
    </record>

    <!-- MCP Module List View -->
    <record id="view_mcp_module_list" model="ir.ui.view">
        <field name="name">mcp.module.list</field>
        <field name="model">mcp.module</field>
        <field name="arch" type="xml">
            <tree string="MCP Modules">
                <field name="name"/>
                <field name="technical_name"/>
                <field name="state"
                       decoration-success="state == 'installed'"
                       decoration-info="state == 'packaged'"
                       decoration-muted="state == 'draft'"
                       widget="badge"/>
                <field name="files_changed" string="Out of Sync"
                       decoration-warning="files_changed"
                       widget="boolean"
                       optional="show"/>
                <field name="installed_module_id" optional="show"/>
                <field name="user_id" widget="many2one_avatar_user"/>
            </tree>
        </field>
    </record>

    <!-- MCP Module Form View -->
    <record id="view_mcp_module_form" model="ir.ui.view">
        <field name="name">mcp.module.form</field>
        <field name="model">mcp.module</field>
        <field name="arch" type="xml">
            <form string="MCP Module">
                <header>
                    <button name="action_package" type="object"
                            string="Package" class="btn-secondary"
                            icon="fa-archive"
                            invisible="not file_ids"
                            title="Generate ZIP file from module files without installing"/>
                    <button name="action_install" type="object"
                            string="Install / Upgrade" class="btn-primary"
                            icon="fa-download"
                            invisible="not file_ids"
                            title="Package and install the module into Odoo (creates or upgrades)"/>
                    <button name="action_uninstall_wizard" type="object"
                            string="Uninstall" class="btn-secondary"
                            icon="fa-trash"
                            invisible="state not in ('installed', 'packaged')"
                            title="Open the uninstall wizard showing dependencies and impact"/>
                    <button name="action_export" type="object"
                            string="Export" class="btn-secondary"
                            icon="fa-download" invisible="not id"
                            title="Export module and files as CSV to chatter"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,packaged,installed"/>
                </header>
                <sheet>
                    <div class="alert alert-warning mb-0" role="alert"
                         invisible="not files_changed or state != 'installed'">
                        <i class="fa fa-exclamation-triangle me-1" title="Out of Sync"/>
                        <strong>Out of sync</strong> — Files have been modified since the last install.
                        The running module does not reflect the current files.
                        Click <strong>Install</strong> to update.
                    </div>
                    <field name="files_changed" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_mcp_module_files)d" type="action"
                                class="oe_stat_button" icon="fa-file-code-o"
                                invisible="not file_ids">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Files</span>
                            </div>
                        </button>
                        <button name="action_open_installed_module" type="object"
                                class="oe_stat_button" icon="fa-puzzle-piece"
                                invisible="not installed_module_id">
                            <field name="installed_module_id" widget="statinfo" string="Odoo Module"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="My Module"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="technical_name" placeholder="x_my_module"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="last_error" readonly="1"
                                   invisible="not last_error"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Files" name="files">
                            <field name="file_ids" nolabel="1">
                                <tree editable="bottom" open_form_view="True">
                                    <field name="sequence" widget="handle"/>
                                    <field name="file_path"/>
                                    <field name="content" widget="text" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Download" name="download"
                              invisible="not zip_file">
                            <group>
                                <field name="zip_file" filename="zip_filename" readonly="1"/>
                                <field name="zip_filename" invisible="1"/>
                            </group>
                        </page>
                        <page string="Documentation" name="documentation">
                            <div class="alert alert-info" role="status">
                                <h5 class="fw-bold mb-3">
                                    <i class="fa fa-book me-2" title="Documentation"/>Importable Data Modules
                                </h5>
                                <p>
                                    Modules are installed via Odoo's <code>base_import_module</code> mechanism.
                                    They are packaged as ZIP files containing a <code>__manifest__.py</code> and data files (XML, CSV).
                                    No Python model files are supported — all models and fields are created as database records.
                                </p>
                                <p class="mb-2">
                                    <a href="https://www.odoo.com/documentation/17.0/developer/tutorials/importable_modules.html"
                                       target="_blank" rel="noopener noreferrer">
                                        <i class="fa fa-external-link me-1" title="External Link"/>Odoo Importable Modules Documentation
                                    </a>
                                </p>
                            </div>
                            <div class="alert alert-info" role="status">
                                <h5 class="fw-bold mb-3">
                                    <i class="fa fa-eye me-2" title="Review"/>Reviewing Code Before Installation
                                </h5>
                                <p>
                                    By default, the MCP tool automatically installs the module after creating or updating files.
                                    If you prefer to <strong>review the code first</strong>, ask the AI to use
                                    <code>skip_install=true</code> — this saves the files without triggering installation.
                                </p>
                                <p class="mb-2">
                                    You can then review the files in the <strong>Files</strong> tab, and when satisfied,
                                    click <strong>Install / Upgrade</strong> to install manually.
                                </p>
                            </div>
                            <div class="alert alert-warning" role="status">
                                <h5 class="fw-bold mb-3">
                                    <i class="fa fa-exclamation-triangle me-2" title="Caution"/>Uninstall &#x26; Reinstall
                                </h5>
                                <p>
                                    The AI tool can use <code>uninstall_first=true</code> to drop all module tables,
                                    columns, and data before reinstalling. This <strong>permanently deletes all user
                                    data</strong> in the module's custom models — only allow this during initial
                                    development when no real data exists.
                                </p>
                                <p class="mb-2">
                                    Once a module has user data, use these alternatives instead:
                                </p>
                                <ul class="mb-2">
                                    <li><strong>Remove leftover fields/models:</strong> delete them manually via
                                        <em>Settings &#x2192; Technical &#x2192; Fields/Models</em>
                                        (remove from views first, then delete the record)</li>
                                    <li><strong>Overwrite noupdate records:</strong> reinstall with
                                        <code>force=true</code> (does not drop tables or columns)</li>
                                </ul>
                            </div>
                            <div class="alert alert-info" role="status">
                                <h5 class="fw-bold mb-3">
                                    <i class="fa fa-exchange me-2" title="Deployment"/>Staging &#x2192; Production Workflow
                                </h5>
                                <p>
                                    The recommended workflow is to develop and test on a <strong>staging</strong> database,
                                    then deploy to <strong>production</strong> using the Export button.
                                </p>
                                <h6 class="fw-bold mt-3 mb-2">
                                    <i class="fa fa-arrow-right me-1" title="First Deploy"/>First deployment
                                </h6>
                                <ol class="mb-2">
                                    <li>On staging: develop, test, and install the module</li>
                                    <li>Click <strong>Export</strong> &#x2192; a CSV is posted to the chatter</li>
                                    <li>On production: go to <strong>MCP &#x2192; Modules</strong>, use the Odoo <strong>Import records</strong> (list view &#x2192; gear icon) to import the CSV</li>
                                    <li>Open the newly created module record and click <strong>Install / Upgrade</strong></li>
                                </ol>
                                <h6 class="fw-bold mt-3 mb-2">
                                    <i class="fa fa-refresh me-1" title="Subsequent Updates"/>Subsequent updates
                                </h6>
                                <ol class="mb-2">
                                    <li>On staging: make changes and re-test</li>
                                    <li>Click <strong>Export</strong> to generate a fresh CSV</li>
                                    <li>On production: <strong>delete the existing MCP module record</strong> (this only removes the file container — the installed Odoo module is unaffected)</li>
                                    <li>Import the new CSV to recreate the module record with updated files</li>
                                    <li>Click <strong>Install / Upgrade</strong> to apply changes</li>
                                </ol>
                                <div class="mt-2 text-muted small">
                                    <i class="fa fa-info-circle me-1" title="Info"/>
                                    <strong>Why delete first?</strong> Reimporting over an existing record may leave
                                    orphan files if any were removed on staging. Deleting and reimporting ensures
                                    the file list exactly matches the source.
                                </div>
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- MCP Module Search View -->
    <record id="view_mcp_module_search" model="ir.ui.view">
        <field name="name">mcp.module.search</field>
        <field name="model">mcp.module</field>
        <field name="arch" type="xml">
            <search string="Search Modules">
                <field name="name"/>
                <field name="technical_name"/>
                <filter name="my_modules" string="My Modules"
                        domain="[('user_id', '=', uid)]"/>
                <filter name="installed" string="Installed"
                        domain="[('state', '=', 'installed')]"/>
                <filter name="draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="has_error" string="Has Error"
                        domain="[('last_error', '!=', False)]"/>
                <group>
                    <filter name="group_state" string="State"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_user" string="User"
                            context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- MCP Module Action -->
    <record id="action_mcp_module" model="ir.actions.act_window">
        <field name="name">Modules</field>
        <field name="res_model">mcp.module</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_mcp_module_search"/>
        <field name="context">{'search_default_my_modules': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first importable module
            </p>
            <p>
                Build Odoo data modules with models, views, security, and more —
                all without Python files. Use the MCP manage_module tool or create
                modules directly here.
            </p>
        </field>
    </record>

    <!-- Menu Item under MCP root -->
    <menuitem id="menu_mcp_modules"
              name="Modules"
              parent="menu_mcp_root"
              action="action_mcp_module"
              sequence="7"
              groups="odoo_remote_mcp.group_mcp_user"/>
</odoo>
