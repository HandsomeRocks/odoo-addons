<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- OAuth Token Search View -->
    <record id="mcp_oauth_token_view_search" model="ir.ui.view">
        <field name="name">mcp.oauth.token.search</field>
        <field name="model">mcp.oauth.token</field>
        <field name="arch" type="xml">
            <search string="Search Tokens">
                <field name="client_id"/>
                <field name="user_id"/>
                <field name="access_token_prefix"/>
            </search>
        </field>
    </record>

    <!-- OAuth Token Action -->
    <record id="action_mcp_oauth_token" model="ir.actions.act_window">
        <field name="name">Access Tokens</field>
        <field name="res_model">mcp.oauth.token</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="mcp_oauth_token_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No active access tokens
            </p>
            <p>
                Access tokens are created when users authenticate via OAuth.
            </p>
        </field>
    </record>


    <!-- OAuth Client List View -->
    <record id="mcp_oauth_client_view_list" model="ir.ui.view">
        <field name="name">mcp.oauth.client.list</field>
        <field name="model">mcp.oauth.client</field>
        <field name="arch" type="xml">
            <tree string="OAuth Clients" decoration-muted="not active" create="0">
                <field name="client_name"/>
                <field name="client_id"/>
                <field name="user_ids" widget="many2many_tags"/>
                <field name="client_type"/>
                <field name="token_endpoint_auth_method"/>
                <field name="registered_at"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- OAuth Client Form View -->
    <record id="mcp_oauth_client_view_form" model="ir.ui.view">
        <field name="name">mcp.oauth.client.form</field>
        <field name="model">mcp.oauth.client</field>
        <field name="arch" type="xml">
            <form string="OAuth Client" create="0">
                <header>
                    <button name="action_revoke_tokens" type="object" string="Revoke All Tokens" class="btn-secondary" confirm="This will revoke all access tokens for this client. Continue?"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(odoo_remote_mcp.action_mcp_oauth_token)d" type="action"
                                class="oe_stat_button" icon="fa-key"
                                context="{'search_default_client_id': id}">
                            <field name="token_ids" widget="statinfo" string="Tokens"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="client_name"/>
                        <h1>
                            <field name="client_name" placeholder="Client Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Client Credentials">
                            <field name="client_id"/>
                            <field name="client_type" readonly="1"/>
                            <field name="token_endpoint_auth_method" readonly="1"/>
                        </group>
                        <group string="Registration">
                            <field name="registered_at"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="OAuth Configuration">
                        <field name="redirect_uris_display" string="Redirect URIs"/>
                        <field name="grant_types" readonly="1"/>
                        <field name="scope" readonly="1"/>
                    </group>
                     <group string="Users">
                        <field name="user_ids" readonly="1" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- OAuth Client Action -->
    <record id="action_mcp_oauth_client" model="ir.actions.act_window">
        <field name="name">OAuth Clients</field>
        <field name="res_model">mcp.oauth.client</field>
        <field name="view_mode">list,form</field>
        <!-- <field name="search_view_id" ref="mcp_oauth_client_view_search"/> -->
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No OAuth clients registered yet
            </p>
            <p>
                OAuth clients are registered automatically when AI agents like Claude connect to your Odoo instance via the MCP endpoint.
            </p>
        </field>
    </record>

    <!-- OAuth Token List View -->
    <record id="mcp_oauth_token_view_list" model="ir.ui.view">
        <field name="name">mcp.oauth.token.list</field>
        <field name="model">mcp.oauth.token</field>
        <field name="arch" type="xml">
            <tree string="Access Tokens" decoration-danger="is_expired" create="0">
                <field name="client_id"/>
                <field name="access_token_prefix"/>
                <field name="user_id"/>
                <field name="scope"/>
                <field name="refresh_expires_at"/>
                <field name="expires_at"/>
                <field name="is_expired"/>
            </tree>
        </field>
    </record>

    <!-- OAuth Token Form View -->
    <record id="mcp_oauth_token_view_form" model="ir.ui.view">
        <field name="name">mcp.oauth.token.form</field>
        <field name="model">mcp.oauth.token</field>
        <field name="arch" type="xml">
            <form string="Access Token" create="0">
                <sheet>
                    <group>
                        <group string="Token Info">
                            <field name="access_token_prefix"/>
                            <field name="client_id" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                        <group string="Validity">
                            <field name="scope" readonly="1"/>
                            <field name="expires_at"/>
                            <field name="refresh_expires_at"/>
                            <field name="is_expired"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
