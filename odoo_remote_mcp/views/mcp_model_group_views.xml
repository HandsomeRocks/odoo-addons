<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- MCP Model Group Form View -->
    <record id="view_mcp_model_group_form" model="ir.ui.view">
        <field name="name">mcp.model.group.form</field>
        <field name="model">mcp.model.group</field>
        <field name="arch" type="xml">
            <form string="Model Group">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g., Sensitive Data"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="model_count" string="Restricted Models" readonly="1"/>
                        </group>
                        <group>
                            <field name="restricted_field_count" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Restricted Models" name="restricted_models">
                            <div class="alert alert-warning mb-3" role="status">
                                <i class="fa fa-ban me-1" title="Restricted"/>
                                <strong>Prevents AI from directly querying restricted models.</strong>
                                Check the operations you want to block for each model.
                                <ul class="mb-0 mt-2">
                                    <li><strong>Empty list:</strong> No model restrictions (all models accessible)</li>
                                    <li><strong>Checked operation:</strong> That operation is BLOCKED for the model</li>
                                    <li><strong>Unchecked operation:</strong> That operation is allowed</li>
                                </ul>
                                <small class="text-muted">
                                    Blocks direct access via MCP tools: search_read, read_record, read_group, create_record, update_record, delete_record.
                                    Does not prevent indirect data access through computed fields or relational field traversal
                                    (e.g., blocking account.move won't prevent sale.order.amount_invoiced from exposing invoice data).
                                    For sensitive fields, use Restricted Fields tab.
                                    execute_orm bypasses all restrictions. execute_method may bypass in edge cases depending on method implementation (e.g., methods using sudo() internally - matches Odoo ACL behavior).
                                </small>
                            </div>
                            <div class="mb-3">
                                <button name="%(action_mcp_model_group_add_models)d"
                                        type="action"
                                        string="Mass Add Restricted Models"
                                        class="btn-danger"
                                        icon="fa-ban"/>
                            </div>
                            <field name="model_line_ids">
                                <tree editable="bottom">
                                    <field name="model_id"
                                           string="Model"
                                           options="{'no_create': True}"/>
                                    <field name="model_name"/>
                                    <field name="perm_read" string="Block Read"/>
                                    <field name="perm_create" string="Block Create"/>
                                    <field name="perm_write" string="Block Write"/>
                                    <field name="perm_unlink" string="Block Delete"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Restricted Fields" name="restricted_fields">
                            <div class="alert alert-warning mb-3" role="status">
                                <i class="fa fa-ban me-1" title="Restricted"/>
                                Fields listed here are blocked from MCP access (independent of Model Restrictions):
                                <ul class="mb-0 mt-2">
                                    <li><strong>Read:</strong> Rejected if explicitly requested in search_read, read_record, or get_model_schema. Silently filtered when requesting all fields.</li>
                                    <li><strong>Write:</strong> Rejected if provided in create_record or update_record</li>
                                </ul>
                                <small class="text-muted">Note: execute_orm and execute_method bypass field restrictions.</small>
                            </div>
                            <field name="restricted_fields" options="{'no_create': True}">
                                <tree create="false" edit="false" delete="false">
                                    <field name="name" string="Field Name"/>
                                    <field name="field_description" string="Field Label"/>
                                    <field name="model_id" string="Model"/>
                                    <field name="ttype" string="Field Type"/>
                                    <field name="relation"/>
                                    <field name="store" string="Stored" optional="hide"/>
                                    <field name="required" optional="hide"/>
                                    <field name="readonly" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- MCP Model Group List View -->
    <record id="view_mcp_model_group_list" model="ir.ui.view">
        <field name="name">mcp.model.group.list</field>
        <field name="model">mcp.model.group</field>
        <field name="arch" type="xml">
            <tree string="Model Groups">
                <field name="name"/>
                <field name="model_count" string="Restricted Models"/>
                <field name="restricted_field_count" string="Restricted Fields"/>
            </tree>
        </field>
    </record>

    <!-- MCP Model Group Action -->
    <record id="action_mcp_model_group" model="ir.actions.act_window">
        <field name="name">Model Groups</field>
        <field name="res_model">mcp.model.group</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a model group
            </p>
            <p>
                Model groups define which Odoo models are BLOCKED from MCP access.
                Add models to restrict AI agent access to sensitive data.
            </p>
        </field>
    </record>
</odoo>
