<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- MCP EChart Form View (Config) -->
    <record id="view_mcp_echart_form" model="ir.ui.view">
        <field name="name">mcp.echart.form</field>
        <field name="model">mcp.echart</field>
        <field name="arch" type="xml">
            <form string="EChart Dashboard">
                <header>
                    <button name="action_view_dashboard" type="object"
                            string="View Dashboard" class="btn-primary"
                            icon="fa-external-link" invisible="not id"/>
                    <button name="action_export" type="object"
                            string="Export" class="btn-secondary"
                            icon="fa-download" invisible="not id"
                            title="Export echart as CSV to chatter for deployment or backup"/>
                </header>
                <sheet>

                    <!-- Title -->
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Dashboard Title"/>
                        </h1>
                        <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"
                               placeholder="Add tags..."/>
                    </div>

                    <group>
                        <group string="Configuration">
                            <field name="dashboard_url" widget="CopyClipboardChar" readonly="1"
                                   invisible="not id"/>
                        </group>
                        <group string="Metadata">
                            <field name="user_id" readonly="1"/>
                            <field name="client_id" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>

                    <field name="description" placeholder="What does this chart visualize?"/>

                    <!-- Notebook with Code and Options -->
                    <notebook>
                        <page string="Data Code" name="data_code">
                            <div class="alert alert-info mb-3" role="status">
                                <strong>Data Code:</strong> Python code that fetches data from Odoo.
                                Assign your result to the <code>result</code> variable.
                                Uses the same safe_eval environment as execute_orm tool.
                            </div>
                            <field name="data_code" widget="code" options="{'mode': 'python'}"/>
                        </page>

                        <page string="Chart Options" name="chart_options">
                            <div class="alert alert-info mb-3" role="status">
                                <strong>Chart Options:</strong> ECharts 6.x configuration JSON.
                                Use <code>$data.xxx</code> placeholders to reference data from your Python code.
                                For custom formatters, prefix JavaScript functions with <code>__fn__:</code>
                                (e.g., <code>"formatter": "__fn__:function(p){return p.value.toLocaleString()}"</code>).
                                <a href="https://echarts.apache.org/en/option.html" target="_blank">ECharts Documentation</a>
                            </div>

                            <group>
                                <field name="renderer" widget="radio" options="{'horizontal': true}"/>
                            </group>
                            <field name="chart_options_text" widget="code" options="{'mode': 'js'}"/>
                        </page>

                        <page string="Responsive" name="responsive">
                            <div class="alert alert-info mb-3" role="status">
                                <strong>Responsive Media Queries:</strong> Use ECharts native <code>baseOption + media</code> system
                                for responsive layouts. Define breakpoints with query conditions (maxWidth, minWidth, maxHeight, minHeight)
                                and option overrides that apply when the query matches.
                                <a href="https://echarts.apache.org/handbook/en/concepts/responsive/" target="_blank">ECharts Responsive Guide</a>
                            </div>
                            <field name="media_queries_text" widget="code" options="{'mode': 'js'}"
                                   placeholder='[&#10;  {&#10;    "query": {"maxWidth": 600},&#10;    "option": {&#10;      "legend": {"orient": "vertical"},&#10;      "series": [{"radius": "50%"}]&#10;    }&#10;  }&#10;]'/>
                        </page>

                        <page string="Sharing" name="sharing">
                            <group>
                                <group string="Internal Sharing">
                                    <field name="share_with_all_users" widget="boolean_toggle"/>
                                    <field name="shared_user_ids" widget="many2many_tags"
                                           options="{'no_create': True}"
                                           invisible="share_with_all_users"/>
                                    <field name="shared_group_ids" widget="many2many_tags"
                                           options="{'no_create': True}"
                                           invisible="share_with_all_users"/>
                                </group>
                            </group>

                            <!-- Public Link Section -->
                            <group string="Public Link (no login required)" invisible="not id">
                                <div colspan="2" class="alert alert-warning mb-0" role="alert">
                                    <i class="fa fa-exclamation-triangle me-1" title="Warning"/>
                                    <strong>Security Note:</strong> Public access executes the data code with
                                    elevated privileges (sudo). Ensure your data code does not expose sensitive
                                    information unintentionally.
                                </div>
                                <field name="public_access_enabled" widget="boolean_toggle"/>
                                <field name="public_token_created_at" readonly="1"
                                       invisible="not public_access_enabled"/>
                                <field name="public_url" widget="CopyClipboardChar" readonly="1"
                                       invisible="not public_access_enabled"/>
                            </group>
                            <div class="mt-3" invisible="not id or not public_access_enabled">
                                <button name="regenerate_public_token" type="object"
                                        string="Regenerate Link" class="btn-secondary"
                                        confirm="This will invalidate the existing public link. Anyone with the old link will no longer have access. Continue?"/>
                            </div>

                            <!-- Embed Code Section -->
                            <group string="Embed on Website" invisible="not id">
                                <field name="embed_code" widget="CopyClipboardChar" readonly="1"/>
                                <div colspan="2" class="text-muted small">
                                    <i class="fa fa-info-circle me-1" title="Info"/>
                                    Uses the public URL when Public Link is enabled, otherwise uses the
                                    internal dashboard URL which requires Odoo login.
                                    Enable Public Link above for embedding on external websites.
                                </div>
                            </group>
                        </page>

                        <page string="Advanced" name="advanced">
                            <div class="alert alert-info mb-3" role="status">
                                <strong>Advanced Options:</strong> Configure ECharts extensions and custom JavaScript.
                                These enable advanced features like 3D charts, word clouds, geographic maps, and event handlers.
                            </div>

                            <group string="ECharts Extensions">
                                <field name="extension_urls" widget="code"
                                       placeholder="https://cdn.jsdelivr.net/npm/echarts-gl@2/dist/echarts-gl.min.js"/>
                                <div class="text-muted small mt-1" colspan="2">
                                    One CDN URL per line. Default includes popular extensions (3D, wordcloud, liquidfill, stat).
                                    Extensions load BEFORE chart initialization.
                                </div>
                            </group>

                            <group string="Pre-Init JavaScript">
                                <field name="pre_init_js" widget="code" options="{'mode': 'js'}"
                                       placeholder="// Runs BEFORE chart.setOption()&#10;// Available: echarts, chartDom, options&#10;// Example: echarts.registerMap('myMap', geoJsonData);"/>
                                <div class="text-muted small mt-1" colspan="2">
                                    Use for <code>echarts.registerMap()</code>, <code>echarts.registerTheme()</code>,
                                    <code>echarts.registerTransform()</code>, or any setup that must happen before the chart renders.
                                </div>
                            </group>

                            <group string="Post-Init JavaScript">
                                <field name="post_init_js" widget="code" options="{'mode': 'js'}"
                                       placeholder="// Runs AFTER chart.setOption()&#10;// Available: echarts, chart, chartDom, options&#10;// Example: chart.on('click', (params) => console.log(params));"/>
                                <div class="text-muted small mt-1" colspan="2">
                                    Use for event handlers (<code>chart.on('click', ...)</code>), drill-down logic,
                                    export buttons, or any post-render customization.
                                </div>
                            </group>
                        </page>

                        <page string="Documentation" name="documentation">
                            <div class="alert alert-info" role="status">
                                <h5 class="fw-bold mb-3">
                                    <i class="fa fa-exchange me-2" title="Deployment"/>Staging &#x2192; Production Workflow
                                </h5>
                                <p>
                                    The recommended workflow is to develop and test on a <strong>staging</strong> database,
                                    then deploy to <strong>production</strong> using the Export button.
                                </p>
                                <h6 class="fw-bold mt-3 mb-2">
                                    <i class="fa fa-arrow-right me-1" title="First Deploy"/>First deployment
                                </h6>
                                <ol class="mb-2">
                                    <li>On staging: create and test the EChart dashboard</li>
                                    <li>Click <strong>Export</strong> &#x2192; a CSV with the external ID is posted to the chatter</li>
                                    <li>On production: go to <strong>MCP &#x2192; ECharts</strong>, use the Odoo <strong>Import records</strong> (list view &#x2192; gear icon) to import the CSV</li>
                                </ol>
                                <h6 class="fw-bold mt-3 mb-2">
                                    <i class="fa fa-refresh me-1" title="Subsequent Updates"/>Subsequent updates
                                </h6>
                                <ol class="mb-2">
                                    <li>On staging: make changes and re-test</li>
                                    <li>Click <strong>Export</strong> to generate a fresh CSV</li>
                                    <li>On production: import the CSV &#x2014; Odoo matches on the external ID and <strong>updates the existing record</strong></li>
                                </ol>
                                <div class="mt-2 text-muted small">
                                    <i class="fa fa-info-circle me-1" title="Info"/>
                                    ECharts are single records with no child files, so reimporting cleanly
                                    overwrites all fields. No delete-and-recreate step is needed.
                                </div>
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- MCP EChart List View (Config) -->
    <record id="view_mcp_echart_list" model="ir.ui.view">
        <field name="name">mcp.echart.list</field>
        <field name="model">mcp.echart</field>
        <field name="arch" type="xml">
            <tree string="EChart Dashboards">
                <field name="name"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" optional="show"/>
                <field name="description" optional="show"/>
                <field name="renderer" optional="hide"/>
                <field name="user_id"/>
                <field name="share_with_all_users" widget="boolean"/>
                <field name="public_access_enabled" widget="boolean" string="Public Link"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <!-- MCP EChart Kanban View (Dashboard Viewer) -->
    <record id="view_mcp_echart_kanban" model="ir.ui.view">
        <field name="name">mcp.echart.kanban</field>
        <field name="model">mcp.echart</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="description"/>
                <field name="user_id"/>
                <field name="tag_ids"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top mb-2">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                            </div>
                            <div class="text-muted small mb-2">
                                <field name="description"/>
                            </div>
                            <div class="mb-2">
                                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <button name="action_view_dashboard" type="object"
                                            class="btn btn-primary btn-sm">
                                        <i class="fa fa-external-link"/> Open
                                    </button>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- MCP EChart Search View -->
    <record id="view_mcp_echart_search" model="ir.ui.view">
        <field name="name">mcp.echart.search</field>
        <field name="model">mcp.echart</field>
        <field name="arch" type="xml">
            <search string="Search ECharts">
                <field name="name"/>
                <field name="description"/>
                <field name="tag_ids"/>
                <field name="user_id"/>
                <filter string="My Charts" name="my_charts"
                        domain="[('user_id', '=', uid)]"/>
                <filter string="Shared with Me" name="shared_with_me"
                        domain="[('user_id', '!=', uid), '|', ('share_with_all_users', '=', True), ('shared_user_ids', 'in', uid)]"/>
                <filter string="Has Public Link" name="public_link"
                        domain="[('public_access_enabled', '=', True)]"/>
                <separator/>
                <filter string="Dashboards" name="dashboards"
                        domain="[('tag_ids.name', 'ilike', 'dashboard')]"/>
                <filter string="Demos" name="demos"
                        domain="[('tag_ids.name', 'ilike', 'demo')]"/>
                <separator/>
                <filter string="Created By" name="group_user"
                        context="{'group_by': 'user_id'}"/>
                <filter string="Tags" name="group_tags"
                        context="{'group_by': 'tag_ids'}"/>
                <filter string="Creation Date" name="group_date"
                        context="{'group_by': 'create_date:month'}"/>
            </search>
        </field>
    </record>

    <!-- Action: ECharts (technical, for creating/editing) -->
    <record id="action_mcp_echart_config" model="ir.actions.act_window">
        <field name="name">ECharts</field>
        <field name="res_model">mcp.echart</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_mcp_echart_kanban')}),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_mcp_echart_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_mcp_echart_form')})]"/>
        <field name="search_view_id" ref="view_mcp_echart_search"/>
        <field name="context">{'search_default_my_charts': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first EChart dashboard
            </p>
            <p>
                ECharts dashboards can be created by AI agents using the create_echart tool,
                or manually via this interface. Use the EChart Dashboards app to view charts.
            </p>
        </field>
    </record>

    <!-- Action: Dashboard Viewer (kanban, for browsing dashboards) -->
    <record id="action_mcp_echart_dashboard" model="ir.actions.act_window">
        <field name="name">Browse Dashboards</field>
        <field name="res_model">mcp.echart</field>
        <field name="view_mode">kanban,tree</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_mcp_echart_kanban')}),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_mcp_echart_list')})]"/>
        <field name="search_view_id" ref="view_mcp_echart_search"/>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No dashboards available
            </p>
            <p>
                Dashboards shared with you will appear here.
                Click "Open" to view a dashboard.
            </p>
        </field>
    </record>

    <!-- Menu: ECharts (under MCP Server, for technical users) -->
    <menuitem
        id="menu_mcp_echarts_config"
        name="ECharts"
        parent="menu_mcp_root"
        action="action_mcp_echart_config"
        sequence="6"
        groups="odoo_remote_mcp.group_mcp_user"/>

    <!-- Menu: EChart Dashboards App (separate top-level app for all internal users) -->
    <menuitem
        id="menu_echart_app_root"
        name="EChart Dashboards"
        web_icon="odoo_remote_mcp,static/description/echartlogo.png"
        sequence="99"
        groups="base.group_user"/>

    <menuitem
        id="menu_echart_dashboards"
        name="Browse Dashboards"
        parent="menu_echart_app_root"
        action="action_mcp_echart_dashboard"
        sequence="1"/>
</odoo>
