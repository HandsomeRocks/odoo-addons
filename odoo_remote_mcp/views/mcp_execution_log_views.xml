    <!-- Execution Log Action -->
    <record id="action_mcp_execution_log" model="ir.actions.act_window">
        <field name="name">Execution Logs</field>
        <field name="res_model">mcp.execution.log</field>
        <field name="view_mode">list,form</field>
        <!-- <field name="search_view_id" ref="mcp_execution_log_view_search"/> -->
        <field name="context">{'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No execution logs yet
            </p>
            <p>
                Execution logs track all tool calls made by AI agents via MCP.
            </p>
        </field>
    </record>
