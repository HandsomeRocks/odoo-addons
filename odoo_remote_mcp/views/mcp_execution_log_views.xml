<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Execution Log List View -->
    <record id="mcp_execution_log_view_list" model="ir.ui.view">
        <field name="name">mcp.execution.log.list</field>
        <field name="model">mcp.execution.log</field>
        <field name="arch" type="xml">
            <tree string="Execution Logs" decoration-danger="not success" decoration-success="success" create="0">
                <field name="create_date"/>
                <field name="user_id"/>
                <field name="client_id"/>
                <field name="api_key_id"/>
                <field name="tool_name"/>
                <field name="success"/>
                <field name="execution_time" widget="float_time"/>
                <field name="ip_address"/>
            </tree>
        </field>
    </record>

    <!-- Execution Log Form View -->
    <record id="mcp_execution_log_view_form" model="ir.ui.view">
        <field name="name">mcp.execution.log.form</field>
        <field name="model">mcp.execution.log</field>
        <field name="arch" type="xml">
            <form string="Execution Log" edit="0" create="0">
                <sheet>
                    <group>
                        <group string="Execution Info">
                            <field name="create_date"/>
                            <field name="user_id"/>
                            <field name="client_id"/>
                            <field name="api_key_id"/>
                            <field name="tool_name"/>
                            <field name="ip_address"/>
                        </group>
                        <group string="Result">
                            <field name="success"/>
                            <field name="execution_time"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Code" name="code" invisible="not code">
                            <field name="code" widget="code" options="{'mode': 'python'}"/>
                        </page>
                        <page string="Parameters" name="parameters" invisible="not parameters">
                            <field name="parameters" widget="code" options="{'mode': 'js'}"/>
                        </page>
                        <page string="Result" name="result" invisible="not result">
                            <field name="result" widget="code" options="{'mode': 'js'}"/>
                        </page>
                        <page string="Error" name="error" invisible="not error">
                            <field name="error"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

