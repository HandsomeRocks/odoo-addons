<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Form View -->
    <record id="view_mcp_model_group_add_models_form" model="ir.ui.view">
        <field name="name">mcp.model.group.add.models.form</field>
        <field name="model">mcp.model.group.add.models</field>
        <field name="arch" type="xml">
            <form string="Add Restricted Models">
                <group>
                    <field name="group_id" invisible="1"/>
                    <field name="model_ids"
                           widget="many2many_tags"
                           options="{'no_create': True}"
                           placeholder="Select models to restrict..."/>
                </group>
                <group string="Operations to Block (checked = blocked)">
                    <group>
                        <field name="perm_read"/>
                        <field name="perm_create"/>
                    </group>
                    <group>
                        <field name="perm_write"/>
                        <field name="perm_unlink"/>
                    </group>
                </group>
                <footer>
                    <button name="action_add_models"
                            string="Add Restrictions"
                            type="object"
                            class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Action -->
    <record id="action_mcp_model_group_add_models" model="ir.actions.act_window">
        <field name="name">Add Restricted Models</field>
        <field name="res_model">mcp.model.group.add.models</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
