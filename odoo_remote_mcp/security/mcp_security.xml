    <!-- MCP Prompts: Users can read/write their own prompts, read shared prompts -->
    <record id="mcp_prompt_rule_user_own" model="ir.rule">
        <field name="name">MCP Prompt: Own Prompts (Full Access)</field>
        <field name="model_id" ref="model_mcp_prompt"/>
        <field name="domain_force">[('owner_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_mcp_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="mcp_prompt_rule_user_shared" model="ir.rule">
        <field name="name">MCP Prompt: Shared Prompts (Read Only)</field>
        <field name="model_id" ref="model_mcp_prompt"/>
        <field name="domain_force">[
            ('owner_id', '!=', user.id),
            '|',
            ('share_with_all_users', '=', True),
            ('shared_user_ids', 'in', [user.id]),
        ]</field>
        <field name="groups" eval="[(4, ref('group_mcp_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

