    <!-- =======================================================================
         MCP WebApp User Storage
         Users can only access their own storage for webapps they have access to
         ======================================================================= -->

    <!-- Storage: MCP Users - own storage for accessible webapps -->
    <record id="mcp_webapp_storage_rule_user" model="ir.rule">
        <field name="name">MCP WebApp Storage: Own Storage (Accessible WebApps)</field>
        <field name="model_id" ref="model_mcp_webapp_user_storage"/>
        <field name="domain_force">[
            ('user_id', '=', user.id),
            '|', '|',
            ('webapp_id.user_id', '=', user.id),
            ('webapp_id.shared_user_ids', 'in', [user.id]),
            ('webapp_id.shared_group_ids', 'in', user.groups_id.ids),
        ]</field>
        <field name="groups" eval="[(4, ref('group_mcp_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Storage: Admin - full access (for debugging/support) -->
    <record id="mcp_webapp_storage_rule_admin" model="ir.rule">
        <field name="name">MCP WebApp Storage: Admin Full Access</field>
        <field name="model_id" ref="model_mcp_webapp_user_storage"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_mcp_admin'))]"/>
    </record>

    <!-- Storage: Internal users - own storage for shared webapps -->
    <record id="mcp_webapp_storage_rule_internal" model="ir.rule">
        <field name="name">MCP WebApp Storage: Internal User (Own Storage, Shared WebApps)</field>
        <field name="model_id" ref="model_mcp_webapp_user_storage"/>
        <field name="domain_force">[
            ('user_id', '=', user.id),
            '|',
            ('webapp_id.shared_user_ids', 'in', [user.id]),
            ('webapp_id.shared_group_ids', 'in', user.groups_id.ids),
        ]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Storage: Portal users - own storage for shared webapps -->
    <record id="mcp_webapp_storage_rule_portal" model="ir.rule">
        <field name="name">MCP WebApp Storage: Portal User (Own Storage, Shared WebApps)</field>
        <field name="model_id" ref="model_mcp_webapp_user_storage"/>
        <field name="domain_force">[
            ('user_id', '=', user.id),
            '|',
            ('webapp_id.shared_user_ids', 'in', [user.id]),
            ('webapp_id.shared_group_ids', 'in', user.groups_id.ids),
        ]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- =======================================================================
         Public User Access (Anonymous/Unauthenticated)
         Public users can only access webapps explicitly shared with base.group_public
         Storage access is session-based and handled entirely in controller logic
         ======================================================================= -->

    <!-- MCP WebApps: Public users - only webapps shared with public group -->
    <record id="mcp_webapp_rule_public_user" model="ir.rule">
        <field name="name">MCP WebApp: Public User (Read Shared Only)</field>
        <field name="model_id" ref="model_mcp_webapp"/>
        <field name="domain_force">[('shared_group_ids', 'in', user.groups_id.ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_public'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- MCP WebApp Pages: Public users - follow parent webapp -->
    <record id="mcp_webapp_page_rule_public_user" model="ir.rule">
        <field name="name">MCP WebApp Page: Public User (Read Shared Only)</field>
        <field name="model_id" ref="model_mcp_webapp_page"/>
        <field name="domain_force">[('webapp_id.shared_group_ids', 'in', user.groups_id.ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_public'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- MCP WebApp Endpoints: Public users - follow parent webapp -->
    <record id="mcp_webapp_endpoint_rule_public_user" model="ir.rule">
        <field name="name">MCP WebApp Endpoint: Public User (Read Shared Only)</field>
        <field name="model_id" ref="model_mcp_webapp_endpoint"/>
        <field name="domain_force">[('webapp_id.shared_group_ids', 'in', user.groups_id.ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_public'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Storage: Public users - session-based access
         Note: Session ID is not available in domain_force context, so this rule
         effectively blocks all ORM access. Storage access for public users MUST
         go through the controller which properly validates session_id.
         The CSV access rights allow controller operations via sudo(). -->
    <record id="mcp_webapp_storage_rule_public" model="ir.rule">
        <field name="name">MCP WebApp Storage: Public User (Controller Only)</field>
        <field name="model_id" ref="model_mcp_webapp_user_storage"/>
        <field name="domain_force">[('id', '=', False)]</field>
        <field name="groups" eval="[(4, ref('base.group_public'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- =======================================================================
         MCP API Keys: Admin only access
         ======================================================================= -->

    <record id="mcp_api_key_rule_admin" model="ir.rule">
        <field name="name">MCP API Key: Admin Full Access</field>
        <field name="model_id" ref="model_mcp_api_key"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_mcp_admin'))]"/>
    </record>

    <!-- =======================================================================
         MCP Modules
         Users can manage their own modules, admins have full access
         ======================================================================= -->

    <record id="mcp_module_rule_user_own" model="ir.rule">
        <field name="name">MCP Module: Own Modules (Full Access)</field>
        <field name="model_id" ref="model_mcp_module"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_mcp_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="mcp_module_rule_admin" model="ir.rule">
        <field name="name">MCP Module: Admin Full Access</field>
        <field name="model_id" ref="model_mcp_module"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_mcp_admin'))]"/>
    </record>

    <!-- MCP Module Files: Follow parent module visibility -->
    <record id="mcp_module_file_rule_user_own" model="ir.rule">
        <field name="name">MCP Module File: Own Modules (Full Access)</field>
        <field name="model_id" ref="model_mcp_module_file"/>
        <field name="domain_force">[('module_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_mcp_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="mcp_module_file_rule_admin" model="ir.rule">
        <field name="name">MCP Module File: Admin Full Access</field>
        <field name="model_id" ref="model_mcp_module_file"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_mcp_admin'))]"/>
    </record>
</odoo>
