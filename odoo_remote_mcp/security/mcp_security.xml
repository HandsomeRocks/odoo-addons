<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- MCP Security Groups -->
    <record id="module_category_mcp" model="ir.module.category">
        <field name="name">Odoo MCP Server</field>
        <field name="description">Model Context Protocol Server for AI Agents</field>
        <field name="sequence">100</field>
    </record>

    <record id="group_mcp_user" model="res.groups">
        <field name="name">MCP User</field>
        <field name="category_id" ref="module_category_mcp"/>
        <field name="comment">Can use MCP tools with read/write access to Odoo data</field>
    </record>

    <record id="group_mcp_admin" model="res.groups">
        <field name="name">MCP Administrator</field>
        <field name="category_id" ref="module_category_mcp"/>
        <field name="comment">Can configure MCP settings and manage OAuth clients</field>
        <field name="implied_ids" eval="[(4, ref('group_mcp_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <!-- Record Rules -->

    <!-- OAuth Clients: Only admins can see all clients -->
    <record id="mcp_oauth_client_rule_admin" model="ir.rule">
        <field name="name">MCP OAuth Client: Admin Full Access</field>
        <field name="model_id" ref="model_mcp_oauth_client"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_mcp_admin'))]"/>
    </record>

    <!-- OAuth Tokens: Users can see their own tokens -->
    <record id="mcp_oauth_token_rule_user" model="ir.rule">
        <field name="name">MCP OAuth Token: Own Tokens</field>
        <field name="model_id" ref="model_mcp_oauth_token"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_mcp_user'))]"/>
    </record>

    <record id="mcp_oauth_token_rule_admin" model="ir.rule">
        <field name="name">MCP OAuth Token: Admin Full Access</field>
        <field name="model_id" ref="model_mcp_oauth_token"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_mcp_admin'))]"/>
    </record>

    <!-- OAuth Codes: Users can see their own codes -->
    <record id="mcp_oauth_code_rule_user" model="ir.rule">
        <field name="name">MCP OAuth Code: Own Codes</field>
        <field name="model_id" ref="model_mcp_oauth_code"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_mcp_user'))]"/>
    </record>

    <record id="mcp_oauth_code_rule_admin" model="ir.rule">
        <field name="name">MCP OAuth Code: Admin Full Access</field>
        <field name="model_id" ref="model_mcp_oauth_code"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_mcp_admin'))]"/>
    </record>

    <!-- Execution Logs: Users can see their own logs -->
    <record id="mcp_execution_log_rule_user" model="ir.rule">
        <field name="name">MCP Execution Log: Own Logs</field>
        <field name="model_id" ref="model_mcp_execution_log"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_mcp_user'))]"/>
    </record>

    <record id="mcp_execution_log_rule_admin" model="ir.rule">
        <field name="name">MCP Execution Log: Admin Full Access</field>
        <field name="model_id" ref="model_mcp_execution_log"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_mcp_admin'))]"/>
    </record>

    <!-- MCP Config: Admin only access -->
    <record id="mcp_config_rule_admin" model="ir.rule">
        <field name="name">MCP Config: Admin Access Only</field>
        <field name="model_id" ref="model_mcp_config"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_mcp_admin'))]"/>
