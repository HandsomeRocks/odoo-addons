<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron job to cleanup expired tokens -->
        <record id="ir_cron_cleanup_expired_tokens" model="ir.cron">
            <field name="name">MCP: Cleanup Expired Tokens</field>
            <field name="model_id" ref="model_mcp_oauth_token"/>
            <field name="state">code</field>
            <field name="code">model._cleanup_expired_tokens()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
        </record>

        <!-- Cron job to cleanup expired authorization codes -->
        <record id="ir_cron_cleanup_expired_codes" model="ir.cron">
            <field name="name">MCP: Cleanup Expired Authorization Codes</field>
            <field name="model_id" ref="model_mcp_oauth_code"/>
            <field name="state">code</field>
            <field name="code">model._cleanup_expired_codes()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
        </record>

        <!-- Cron job to cleanup old execution logs -->
        <record id="ir_cron_cleanup_old_logs" model="ir.cron">
            <field name="name">MCP: Cleanup Old Execution Logs</field>
            <field name="model_id" ref="model_mcp_execution_log"/>
            <field name="state">code</field>
            <field name="code">model._cleanup_old_logs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <!-- Cron job to cleanup expired anonymous session storage -->
        <record id="ir_cron_cleanup_expired_session_storage" model="ir.cron">
            <field name="name">MCP: Cleanup Expired Session Storage</field>
            <field name="model_id" ref="model_mcp_webapp_user_storage"/>
            <field name="state">code</field>
            <field name="code">model._cleanup_expired_sessions()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
    </data>


</odoo>
